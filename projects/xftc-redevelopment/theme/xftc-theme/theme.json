{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "color": {
            "palette": [
                { "slug": "xftc-gold",       "color": "#F5A623", "name": "XFTC Gold" },
                { "slug": "xftc-gold-dark",  "color": "#D4880A", "name": "XFTC Gold Dark" },
                { "slug": "xftc-black",      "color": "#111111", "name": "XFTC Black" },
                { "slug": "xftc-dark",       "color": "#1A1A2E", "name": "XFTC Dark" },
                { "slug": "xftc-blue",       "color": "#0F3460", "name": "XFTC Blue" },
                { "slug": "xftc-white",      "color": "#FFFFFF", "name": "XFTC White" },
                { "slug": "xftc-gray",       "color": "#F8F9FA", "name": "XFTC Gray" }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "heading",
                    "name": "Bebas Neue / Impact",
                    "fontFamily": "'Bebas Neue', Impact, 'Arial Narrow', sans-serif"
                },
                {
                    "slug": "body",
                    "name": "Inter",
                    "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
                }
            ],
            "fontSizes": [
                { "slug": "small",   "size": "0.85rem", "name": "Small" },
                { "slug": "normal",  "size": "1rem",    "name": "Normal" },
                { "slug": "medium",  "size": "1.25rem", "name": "Medium" },
                { "slug": "large",   "size": "1.75rem", "name": "Large" },
                { "slug": "x-large", "size": "2.5rem",  "name": "XL" },
                { "slug": "huge",    "size": "4rem",    "name": "Huge" }
            ]
        },
        "spacing": {
            "units": ["px", "%", "em", "rem", "vw", "vh"]
        },
        "layout": {
            "contentSize": "760px",
            "wideSize": "1200px"
        },
        "blocks": {
            "core/button": {
                "color": {
                    "background": true,
                    "text": true
                }
            }
        }
    },
    "styles": {
        "color": {
            "background": "#FFFFFF",
            "text": "#343A40"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--body)",
            "fontSize": "1rem",
            "lineHeight": "1.6"
        },
        "elements": {
            "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "letterSpacing": "0.03em" } },
            "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)", "letterSpacing": "0.03em" } },
            "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)" } },
            "link": {
                "color": { "text": "#0F3460" },
                ":hover": { "color": { "text": "#F5A623" } }
            }
        }
    }
}
