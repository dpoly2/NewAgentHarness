# AgentHarness v2 — Environment Configuration
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0

# ─── Security ─────────────────────────────────────────────────────
# Set a strong random token to protect the API when exposed to the internet.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty for open LAN-only mode (NOT safe for internet exposure).
ACCESS_TOKEN=

# Comma-separated allowed origins for CORS. Use * for open (LAN mode).
# Example: http://localhost:3000,http://192.168.0.14:4000
ALLOWED_ORIGINS=*

# ─── AI Provider ──────────────────────────────────────────────────
# These can also be set in the Settings UI and are stored in data/ai_config.json
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GITHUB_TOKEN=ghp_...
