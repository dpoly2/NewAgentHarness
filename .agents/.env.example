# ============================================================
#  ArchonHub — Environment Configuration Template
#  Copy this file to .agents/.env and fill in your values.
#
#  cp .agents/.env.example .agents/.env
# ============================================================

# ── LLM / AI Keys ────────────────────────────────────────────
# Required: OpenAI key for LangGraph agent execution
OPENAI_API_KEY=sk-...

# Optional: Anthropic / Claude support
ANTHROPIC_API_KEY=

# Optional: LLM model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Hub Server ────────────────────────────────────────────────
# Port the hub server listens on (default: 8765)
HUB_PORT=8765

# Host binding (default: 0.0.0.0 — all interfaces)
# Change to 127.0.0.1 to restrict to localhost only
HUB_HOST=0.0.0.0

# ── Security ──────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE-ME-use-a-long-random-string-in-production

# Admin account password (default: ArchonHub2024!)
# The admin user is seeded on first startup using this value.
ADMIN_PASSWORD=ArchonHub2024!

# ── Email / OAuth Connectors (optional) ─────────────────────
# Used by oauth_connector.py for email integrations
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# ── Logging ──────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
